<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Foodie Hub</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #fff8f0;
            color: #333;
        }

        header {
            background: linear-gradient(to right, #ff6b00, #ff9f43);
            color: white;
            text-align: center;
            padding: 30px 20px;
        }

        header h1 {
            font-size: 42px;
            margin-bottom: 10px;
        }

        header p {
            font-size: 18px;
        }

        .hero {
            text-align: center;
            padding: 40px 20px;
        }

        .hero h2 {
            font-size: 32px;
            color: #ff6b00;
            margin-bottom: 15px;
        }

        .hero p {
            font-size: 18px;
            color: #555;
        }

        .menu {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 25px;
            padding: 30px;
        }

        .card {
            background: white;
            width: 260px;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 4px 14px rgba(0,0,0,0.15);
            text-align: center;
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

        .card h3 {
            margin: 15px 0 8px;
            color: #ff6b00;
        }

        .card p {
            padding: 0 15px;
            color: #666;
            margin-bottom: 10px;
        }

        .price {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 15px;
            color: #222;
        }

        .btn {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 18px;
            background: #ff6b00;
            color: white;
            text-decoration: none;
            border-radius: 8px;
        }

        .btn:hover {
            background: #e65c00;
        }

        footer {
            text-align: center;
            background: #222;
            color: white;
            padding: 18px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <header>
        <h1>🍔 Foodie Hub</h1>
        <p>Fresh, Tasty and Fast Delivery</p>
    </header>

    <section class="hero">
        <h2>Welcome to Our Food Website</h2>
        <p>Enjoy delicious meals made with love and delivered with care.</p>
    </section>

    <section class="menu">
        <div class="card">
            <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=800&q=80" alt="Burger">
            <h3>Cheese Burger</h3>
            <p>Juicy grilled burger with cheese and fresh veggies.</p>
            <div class="price">₹149</div>
            <a href="#" class="btn">Order Now</a>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1513104890138-7c749659a591?auto=format&fit=crop&w=800&q=80" alt="Pizza">
            <h3>Italian Pizza</h3>
            <p>Loaded with cheese, olives, and fresh toppings.</p>
            <div class="price">₹249</div>
            <a href="#" class="btn">Order Now</a>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9?auto=format&fit=crop&w=800&q=80" alt="Pasta">
            <h3>White Sauce Pasta</h3>
            <p>Creamy pasta cooked with herbs and vegetables.</p>
            <div class="price">₹199</div>
            <a href="#" class="btn">Order Now</a>
        </div>
    </section>

    <footer>
        <p>© 2026 Foodie Hub | DevOps Project by Asad</p>
    </footer>

</body>
</html>